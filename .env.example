# Local release packaging settings.
#
# Copy this file to `.env` and fill in values for your local machine.
# Do not commit `.env`.

# Exact identity from:
# security find-identity -v -p codesigning
POWERLENS_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Keychain profile created with:
# xcrun notarytool store-credentials powerlens-notary --apple-id ... --team-id ... --password ...
POWERLENS_NOTARY_PROFILE="powerlens-notary"
